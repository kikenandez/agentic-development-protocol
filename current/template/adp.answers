# ADP answers — fill the values, then run:  scripts/adp-fill.sh .   (or: node scripts/adp-fill.mjs .)
#
# SYNTAX
#   KEY=value          one per line; everything after the FIRST '=' is the value
#   # ...              lines starting with '#' are comments (the "e.g." hints below) — ignored
#   KEY=               leave blank to skip a key (fill it later by hand)
#   No quotes needed. Spaces and commas are fine. Put multi-item values (paths, lists)
#   comma-separated on ONE line. Keep each value to a single line.
#
# NOTE: this file does NOT include codebase_index.txt — that's auto-generated by
#       scripts/generate_map.py (never hand-filled). Run it after install.
#       generate_map.py currently indexes PYTHON (.py) only; JS/TS/HTML/other are not
#       indexed. The codebase index is optional — the rest of ADP is language-agnostic.
#
# Tip: the ownership lanes (DEV_/DESIGN_OWNED_PATHS, DO_NOT_TOUCH) are a design
# decision — set them deliberately, or leave blank and let a first architect
# session (docs/prompts/initialize.md) propose them.

# --- Core (most installs need these) ---------------------------------------
# e.g.  TaskFlow — internal tool for tracking client work
PROJECT_NAME=
# e.g.  Python 3.12 + FastAPI + Postgres (backend); React 18 + TypeScript + Vite (frontend)
STACK=
# e.g.  docker compose up   (api :8000, web :5173, db :5432)
LOCAL_RUN=
# e.g.  GitHub Actions on push to main -> Fly.io
DEPLOY=
# e.g.  pytest tests/ -q
TEST_CMD=
# 3-7 timeless rules, one sentence each. e.g.  1) DB access only via repos/. 2) Secrets from env, never hardcoded. 3) Endpoints return Pydantic schemas.
ARCH_RULES=
# internal acronyms / codenames a fresh session should know. e.g.  Dispatch=the pickup block; Lane=a role's owned paths
GLOSSARY=

# --- Developer lane ---------------------------------------------------------
# LANES ARE FOR YOUR PRODUCT CODE DIRS ONLY. Do NOT list ANY ADP-installed path here
# (docs/tasks/, docs/plans/, docs/prompts/, docs/skills/, memory/, .adp/,
# .agentic-protocol/, .claude/, .github/workflows/) — they're governed by process.md §4.
# current.md + .adp/ are co-edited/machine-managed; locking them breaks the flow.
# comma-separated CODE paths this role OWNS. e.g.  api/, db/, tests/, scripts/
DEV_OWNED_PATHS=
# CODE paths this role must NOT edit (usually the other roles' code). e.g.  web/, .github/
DEV_DO_NOT_TOUCH=

# --- Designer lane (delete/skip if no UI) -----------------------------------
# e.g.  web/src/, web/public/locales/, web/tests/e2e/
DESIGN_OWNED_PATHS=
# e.g.  api/, db/, scripts/
DESIGN_DO_NOT_TOUCH=
# e.g.  React 18 + TypeScript + Tailwind, built with Vite
UI_STACK=
# where design tokens live. e.g.  web/src/styles/tokens.css
DESIGN_TOKENS=
# e.g.  en, fr, es   (or:  en only — no i18n yet)
I18N_LOCALES=
# e.g.  npm --prefix web run build
BUILD_CMD=
# end-to-end test command. e.g.  npm run test:e2e
E2E_CMD=
# e.g.  #2563EB (blue-600)
COLOR_PRIMARY=
# e.g.  #DC2626 (red-600)
COLOR_DANGER=
# e.g.  Inter; 12/14/16/20/24/32px
TYPE_SCALE=
# e.g.  4px base: 4/8/12/16/24/32/48
SPACING_SCALE=
# e.g.  web/src/components/
COMPONENT_DIR=
# e.g.  PascalCase.tsx + co-located PascalCase.test.tsx
COMPONENT_FILE_CONVENTION=
# e.g.  TanStack Query for server state; React Context for theme only
STATE_CONVENTION=

# --- Operational quick-ref skill --------------------------------------------
# 2-3 lines on the architecture. e.g.  3-tier: React SPA -> FastAPI REST -> Postgres; JWT auth
ARCHITECTURE_SUMMARY=
# e.g.  api/main.py
BACKEND_ENTRY=
# e.g.  web/src/main.tsx
FRONTEND_ENTRY=
# e.g.  api/config.py, .env.example
CONFIG_PATHS=
# e.g.  db/migrations/
MIGRATIONS_PATH=
# e.g.  .github/workflows/
CI_PATH=
# run ONE test. e.g.  pytest tests/test_<module>.py::<test> -q
TEST_ONE_CMD=
# e.g.  ruff check . && ruff format --check .
LINT_CMD=
# e.g.  flyctl deploy
DEPLOY_CMD=
# one common gotcha a new session should know. e.g.  the emulator caches modules — restart after a pull (Gate 0)
GOTCHA_1=

# --- Business / comms / analyst (skip if not using those roles) -------------
# e.g.  small-team leads tracking work across projects
TARGET_USER=
# one line on what the product does. e.g.  TaskFlow helps small teams dispatch and track work without ceremony.
USER_BRIEF=
# e.g.  docs/operations/feedback-log.md
FEEDBACK_LOG_PATH=
# one file stating voice + claims you may / may not make. e.g.  docs/brand.md
BRAND_CANON_PATH=
# dirs the comms role may write. e.g.  docs/marketing/, docs/operations/investor/
CONTENT_LANES=

# --- Contract-enforcement & design-principles skill detail (optional) -------
# a domain rule + how to check it. e.g.  DOMAIN_RULE_1=all timestamps stored UTC  /  HOW_TO_CHECK_1=grep for naive datetimes in api/
DOMAIN_RULE_1=
HOW_TO_CHECK_1=
DOMAIN_RULE_2=
HOW_TO_CHECK_2=
DOMAIN_RULE_3=
HOW_TO_CHECK_3=
# a UI invariant + why. e.g.  UI_INVARIANT_1=prices always show currency + VAT state  /  WHY_1=post-launch audit found ambiguous totals
UI_INVARIANT_1=
WHY_1=
